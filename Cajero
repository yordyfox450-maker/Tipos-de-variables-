# Sistema Cajero Automático versión en clase
saldo = 1500 # Saldo inicial
print('=' * 35)
print(' BIENVENIDO AL CAJERO VIRTUAL')
print('=' * 35)

#opciones
print('¿Qué deseas hacer?')
print('1 Consultar saldo')
print('2. Retirar dinero')
print('3. Salir')
print('-' * 35)
opcion = input('Elige una opción: ')

#validacion de datos
if opcion not in ['1', '2', '3']:
    print('Opción no válida. Por favor elige 1, 2 o 3.')

elif opcion == '1':
    print(f'Tu saldo actual es: ${saldo}')
elif opcion == '2':
    monto = float(input('¿Cuanto desea retirar?: '))
    if monto <= 0:
        print('El monto debe ser mayor a 0.')
    elif monto > saldo:
        print(f'Saldo insuficiente. Solo tienes: ${saldo}')
    else:
        saldo -= monto
        print(f'Retiro exitoso. Tu nuevo saldo es: ${saldo}')

elif opcion == '3':
    print('Gracias por usar el cajero virtual. ¡Hasta pronto!')

# Opción para depositar dinero
elif opcion == '4':
    monto = float(input('¿Cuánto desea depositar?: '))
    if monto <= 0:
        print('El monto debe ser mayor a 0.')
    else:
        saldo += monto
        print(f'Depósito exitoso. Tu nuevo saldo es: ${saldo}')