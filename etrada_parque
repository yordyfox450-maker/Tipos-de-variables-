# Sistema de cobro en el parque
# Desafío de la estatura: además de la edad, se valida la altura en ciertos casos

# Se solicita al usuario ingresar la edad del visitante
edad = int(input("Ingrese la edad del visitante: "))

# Se solicita el día de la semana
dia = input("Ingrese el día de la semana: ")

# Validación inicial: si la edad es menor que 0 o mayor que 120, no es válida
if edad < 0 or edad > 120:
    print("Valor inválido, por favor ingrese una edad valida.")

#1: menores de 3 años entran gratis
elif edad < 3:
    print("Entrada gratis")

# 2: niños entre 3 y 12 años pagan $8.000
elif edad >= 3 and edad <= 12:
    precio=8000
    if dia.lower()=="miercoles":
        precio=precio * 0.8
        #Descuento del 20%
    print(f"paga ${precio:.0f}")
    print("Entrada de niño")

#3: adultos entre 13 y 60 años pagan $15.000
elif edad >= 13 and edad <= 60:
    precio=15000
    if dia.lower()=="miercoles":
        precio=precio * 0.8
        #Descuento del 20%
    print(f"paga ${precio:.0f}")
    print("Entrada de adulto")
    
    # Desafío de la estatura: se pide la altura en metros
    estatura=float(input("Ingrese su estatura en metros: "))
    
    # Si mide menos de 1.40m, se muestra un aviso adicional
    if estatura < 1.40:
        print("Puedes entrar, pero no puede subirse a las montañas rusas")
    else:
        print("El visitante puede entrar a todas las atracciones.")

# 4: adultos mayores (más de 60 hasta 120) pagan $10.000
elif edad > 60 and edad <= 120:
    precio=10.000
    if dia.lower()=="miercoles":
        precio=precio * 0.8
        #Descuento del 20%
    print(f"paga ${precio:.0f}")
    print("Entrada de adulto mayor")
